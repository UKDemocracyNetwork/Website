{{!< default}}

{{!-- Ghost REQUIRES an index.hbs; it's the fallback used for tag and author
     archives (e.g. /tag/bulletin/). The main bulletins listing is in
     bulletins.hbs — edit that, not this. --}}

<h1>{{meta_title}}</h1>

{{#if posts}}
<div class="post-list">
    {{#foreach posts}}
    <article class="post-card">
        <h2 class="post-card__title"><a href="{{url}}">{{title}}</a></h2>
        <p class="post-meta"><time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMMM YYYY"}}</time></p>
    </article>
    {{/foreach}}
</div>

{{pagination}}
{{else}}
<p>Nothing here yet.</p>
{{/if}}
